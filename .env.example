# AgiliPet — variáveis de ambiente para docker-compose
# Copie para .env e preencha com valores reais

# Domínio do Caddy (ex: agilipet.com.br)
DOMAIN=seu-dominio.com.br

# WhatsApp Evolution API — chave secreta (nunca commite o valor real)
EVOLUTION_API_KEY=troque_por_chave_forte

# URL pública do Evolution API (use o domínio com caminho se usar Caddy)
EVOLUTION_SERVER_URL=https://seu-dominio.com.br/whatsapp-api
