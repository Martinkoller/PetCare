generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  cnpj        String   @unique
  email       String   @unique
  phone       String?
  zipCode     String?
  street      String?
  number      String?
  complement  String?
  neighborhood String?
  city        String?
  state       String?
  status      String   @default("trial") // 'trial' | 'active' | 'inactive'
  plan        String   @default("essencial") // 'essencial' | 'hotel' | 'clinica'
  trialEndsAt DateTime
  confirmedAt DateTime?
  emailConfirmationToken String? @db.VarChar(512)
  emailConfirmationExpiresAt DateTime?
  settings    String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users                User[]
  clients              Client[]
  pets                 Pet[]
  appointments         Appointment[]
  medicalRecords       MedicalRecord[]
  vaccinations         Vaccination[]
  serviceCatalogItems  ServiceCatalogItem[]
  products             Product[]
  kennels              Kennel[]
  boardingStays        BoardingStay[]
  sales                Sale[]
  tasks                Task[]
  appointmentTemplates AppointmentTemplate[]
  messageTemplates     MessageTemplate[]
  notificationLogs     NotificationLog[]
  hospitalizationStays HospitalizationStay[]
  clientOrders         ClientOrder[]
  clientPortalAccesses ClientPortalAccess[]

  @@map("organizations")
}

model User {
  id             String   @id @default(uuid())
  organizationId String?
  email          String   @unique
  passwordHash   String
  name           String?
  role           String   @default("attendant") // 'saas_admin' | 'admin' | 'veterinarian' | 'attendant' | 'groomer'
  phone          String?
  color          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@map("users")
}

model Client {
  id               String    @id @default(uuid())
  organizationId   String
  name             String
  email            String?
  phone            String?
  cpf              String?
  address          String?
  notes            String?   @db.Text
  whatsappEnabled  Boolean   @default(false)
  joinedAt         DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  birthDate        DateTime?
  gender           String?
  city             String?
  state            String?
  neighborhood     String?
  street           String?
  number           String?
  complement       String?
  zipCode          String?
  acceptsCampaigns Boolean   @default(true)
  blockCredit      Boolean   @default(false)
  origin           String?

  organization  Organization        @relation(fields: [organizationId], references: [id])
  pets          Pet[]
  interactions  ClientInteraction[]
  orders        ClientOrder[]
  portalAccess  ClientPortalAccess?

  @@map("clients")
}

model ClientInteraction {
  id          String   @id @default(uuid())
  clientId    String
  type        String
  origin      String   @default("manual")
  subject     String
  body        String?  @db.Text
  status      String   @default("done")
  petName     String?
  relatedTo   String?
  responsible String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_interactions")
}

model Pet {
  id             String    @id @default(uuid())
  organizationId String
  clientId       String
  name           String
  species        String?
  breed          String?
  age            Int?
  gender         String?
  birthDate      DateTime?
  weight         Float?
  size           String?
  color          String?
  avatar         String?
  notes          String?   @db.Text
  isCastrated    Boolean?  @default(false)
  clinicalAlert  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization         Organization          @relation(fields: [organizationId], references: [id])
  client               Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointments         Appointment[]
  medicalHistory       MedicalRecord[]
  vaccinations         Vaccination[]
  hospitalizationStays HospitalizationStay[]

  @@map("pets")
}

model Appointment {
  id                          String    @id @default(uuid())
  organizationId              String
  petId                       String
  professionalId              String?
  serviceType                 String
  date                        DateTime
  duration                    Int       @default(30)
  price                       Float?
  status                      String    @default("scheduled")
  notes                       String?   @db.Text
  serviceItems                String?   @db.Text
  returnDate                  DateTime?
  startedAt                   DateTime?
  currentStageStartedAt       DateTime?
  priority                    String    @default("normal")
  appointmentType             String    @default("scheduled")
  tutorNotified               Boolean   @default(false)
  tutorNotifiedAt             DateTime?
  tutorNotifiedMessage        String?   @db.Text
  // Grooming — preferências do serviço
  groomingPreferences         String?   @db.Text
  // Grooming — ajuste manual de valor
  priceAdjustment             Float?    @default(0)
  priceAdjustmentReason       String?
  // Grooming — check-in operacional
  checkinArrivalTime          DateTime?
  checkinMatting              String?
  checkinFleas                Boolean?
  checkinBehavior             String?
  checkinExtraAuthorized      Boolean?
  checkinNotes                String?   @db.Text
  // Grooming — histórico de etapas
  stageHistory                String?   @db.Text
  whatsappConfirmationStatus  String?
  whatsappConfirmationSentAt  DateTime?
  whatsappConfirmationReplyAt DateTime?
  awaitingWhatsappReply       Boolean   @default(false)
  whatsappLastMessageId       String?
  whatsappReplyText           String?   @db.Text
  confirmedVia                String?
  reminderSentAt              DateTime?
  confirmationRequestSentAt   DateTime?
  followUpSentAt              DateTime?
  completedAt                 DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  organization        Organization         @relation(fields: [organizationId], references: [id])
  pet                 Pet                  @relation(fields: [petId], references: [id], onDelete: Cascade)
  boardingStay        BoardingStay?
  hospitalizationStay HospitalizationStay?

  @@map("appointments")
}

model MedicalRecord {
  id                  String   @id @default(uuid())
  organizationId      String
  petId               String
  date                DateTime
  description         String   @db.Text
  diagnosis           String?
  diagnosisType       String?
  painScore           Int?
  mucousMembranes     String?
  capillaryRefillTime String?
  hydrationLevel      String?
  bodyConditionScore  String?
  systemicEvaluation  String?  @db.Text
  treatment           String?  @db.Text
  veterinarianId      String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  pet          Pet          @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@map("medical_records")
}

model Vaccination {
  id             String    @id @default(uuid())
  organizationId String
  petId          String
  name           String
  date           DateTime
  nextDueDate    DateTime?
  batch          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  pet          Pet          @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@map("vaccinations")
}

model ServiceCatalogItem {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  category       String
  price          Float
  duration       Int?
  active         Boolean  @default(true)
  description    String?  @db.Text
  observations   String?  @db.Text
  alerts         String?
  parentId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id])
  parent       ServiceCatalogItem?  @relation("SubServices", fields: [parentId], references: [id])
  children     ServiceCatalogItem[] @relation("SubServices")

  @@map("service_catalog")
}

model Product {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  category       String
  sku            String
  price          Float
  stock          Int       @default(0)
  minStock       Int       @default(5)
  description    String?   @db.Text
  unit           String?
  expirationDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id])
  batches      ProductBatch[]

  @@map("products")
}

model ProductBatch {
  id             String   @id @default(uuid())
  productId      String
  code           String
  quantity       Int
  expirationDate DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_batches")
}

model Kennel {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  size           String
  status         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("kennels")
}

model BoardingStay {
  id                  String    @id @default(uuid())
  organizationId      String
  petId               String
  appointmentId       String?   @unique
  checkIn             DateTime
  checkOut            DateTime
  actualCheckIn       DateTime?
  actualCheckOut      DateTime?
  kennelNumber        String
  status              String
  notes               String?   @db.Text
  dailyRate           Float
  totalPrice          Float?
  specialInstructions String?   @db.Text
  belongings          String?   @db.Text
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id])
  appointment  Appointment?      @relation(fields: [appointmentId], references: [id])
  services     BoardingService[]

  @@map("boarding_stays")
}

model BoardingService {
  id         String   @id @default(uuid())
  boardingId String
  serviceId  String?
  productId  String?
  batchId    String?
  name       String
  quantity   Int
  unitPrice  Float
  totalPrice Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  boarding BoardingStay @relation(fields: [boardingId], references: [id], onDelete: Cascade)

  @@map("boarding_services")
}

model Sale {
  id             String   @id @default(uuid())
  organizationId String
  date           DateTime @default(now())
  clientId       String?
  petId          String?
  total          Float
  status         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  items        SaleItem[]

  @@map("sales")
}

model SaleItem {
  id          String  @id @default(uuid())
  saleId      String
  productId   String
  productName String
  quantity    Int
  unitPrice   Float
  total       Float
  batchId     String?

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("sale_items")
}

model Task {
  id              String   @id @default(uuid())
  organizationId  String
  title           String
  description     String?  @db.Text
  category        String
  assignee        String
  dueDate         DateTime
  status          String
  priority        String
  notifiedOverdue Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("tasks")
}

model AppointmentTemplate {
  id                  String   @id @default(uuid())
  organizationId      String
  name                String
  description         String   @db.Text
  services            String   @db.Text
  defaultDurationDays Int
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("appointment_templates")
}

model MessageTemplate {
  id             String   @id @default(uuid())
  organizationId String
  type           String
  title          String
  content        String   @db.Text
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("message_templates")
}

model NotificationLog {
  id             String   @id @default(uuid())
  organizationId String
  clientId       String
  clientName     String
  petName        String?
  type           String
  message        String   @db.Text
  sentAt         DateTime @default(now())
  status         String   @default("sent")
  manual         Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("notification_logs")
}

model HospitalizationStay {
  id                    String    @id @default(uuid())
  organizationId        String
  petId                 String
  appointmentId         String?   @unique
  veterinarianId        String?
  // Campos clínicos de admissão
  origin                String?   // 'appointment' | 'emergency' | 'post_surgery' | 'return' | 'referral' | 'walk_in'
  attendingVetName      String?
  weightAtAdmission     Float?
  triageLevel           String?   // 'low' | 'medium' | 'high' | 'critical'
  reasonForAdmission    String?   @db.Text
  presumptiveDiagnosis  String?   @db.Text
  initialNotes          String?   @db.Text
  // Status e timestamps
  status                String    @default("admitted")
  admittedAt            DateTime  @default(now())
  checkIn               DateTime  @default(now())
  checkOut              DateTime?
  dischargeAt           DateTime?
  bedReleasedAt         DateTime?
  // Campos de alta
  dischargeType         String?   // 'discharge' | 'transfer' | 'death' | 'cancelled'
  dischargeCondition    String?   // 'stable' | 'improved' | 'critical' | 'deceased'
  finalDiagnosis        String?   @db.Text
  dischargeSummary      String?   @db.Text
  dischargeInstructions String?   @db.Text
  dischargeMedications  String?   @db.Text
  returnRecommendation  String?
  administrativeNotes   String?   @db.Text
  // Legado
  dailyRate             Float?
  kennelNumber          String?
  expectedDischargeDate DateTime?
  notes                 String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id])
  pet          Pet                  @relation(fields: [petId], references: [id], onDelete: Cascade)
  appointment  Appointment?         @relation(fields: [appointmentId], references: [id])
  logs         HospitalizationLog[]

  @@map("hospitalization_stays")
}

model HospitalizationLog {
  id                String   @id @default(uuid())
  hospitalizationId String
  type              String   @default("medical_evolution")
  eventAt           DateTime?
  // Vitais
  heartRate         Int?
  respiratoryRate   Int?
  temperature       Float?
  painScore         Int?
  capillaryRefillTime String?
  mucousMembranes   String?
  hydrationLevel    String?
  consciousness     String?
  // Checks clínicos (JSON)
  clinicalChecks    String?  @db.Text
  // Texto
  doctorNotes       String?  @db.Text
  conduct           String?  @db.Text
  statusAfter       String?
  // Legado
  medicationGiven   String?
  timestamp         DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  hospitalization HospitalizationStay @relation(fields: [hospitalizationId], references: [id], onDelete: Cascade)

  @@map("hospitalization_logs")
}

// ── Portal do Tutor ───────────────────────────────────────────────────────────

model ClientPortalAccess {
  id             String    @id @default(uuid())
  organizationId String
  clientId       String    @unique
  email          String    @unique
  passwordHash   String
  status         String    @default("pending") // 'pending' | 'approved' | 'rejected'
  approvedAt     DateTime?
  approvedBy     String?   // userId de quem aprovou
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_portal_accesses")
}

model ClientOrder {
  id             String   @id @default(uuid())
  organizationId String
  clientId       String
  items          String   @db.Text // JSON: [{id, name, price, qty, type}]
  total          Float
  status         String   @default("pending") // 'pending' | 'confirmed' | 'cancelled'
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  client       Client       @relation(fields: [clientId], references: [id])

  @@map("client_orders")
}
