generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String   @default("attendant") // 'admin', 'veterinarian', 'attendant', 'groomer'
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  organizationId String?
  phone          String?

  @@map("users")
}

model Client {
  id              String    @id @default(uuid())
  name            String
  email           String?
  phone           String?
  cpf             String?
  address         String?
  notes           String?
  whatsappEnabled Boolean   @default(false)
  joinedAt        DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  birthDate       DateTime?
  gender          String?
  city            String?
  state           String?
  neighborhood    String?
  street          String?
  number          String?
  complement      String?
  zipCode         String?
  acceptsCampaigns Boolean  @default(true)
  blockCredit      Boolean  @default(false)
  origin           String?
  pets            Pet[]
  interactions    ClientInteraction[]

  @@map("clients")
}

model ClientInteraction {
  id          String   @id @default(uuid())
  clientId    String
  type        String
  origin      String   @default("manual")
  subject     String
  body        String?
  status      String   @default("done")
  petName     String?
  relatedTo   String?
  responsible String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_interactions")
}

model Pet {
  id        String   @id @default(uuid())
  clientId  String
  name      String
  species   String?
  breed     String?
  age       Int?
  gender    String?
  birthDate DateTime?
  weight    Float?
  size      String?
  color     String?
  avatar    String?
  notes     String?
  isCastrated Boolean? @default(false)
  clinicalAlert String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client        Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  medicalHistory MedicalRecord[]
  vaccinations   Vaccination[]
  hospitalizationStays HospitalizationStay[]

  @@map("pets")
}

model Appointment {
  id            String   @id @default(uuid())
  petId         String
  professionalId String?
  serviceType   String // 'grooming', 'veterinary', 'boarding'
  date          DateTime
  duration      Int      @default(30)
  price         Float?
  status        String   @default("scheduled") // 'scheduled', 'confirmed', 'completed', 'cancelled'
  notes         String?
  serviceItems          String?
  returnDate            DateTime?
  startedAt             DateTime?
  currentStageStartedAt DateTime?
  priority              String    @default("normal")
  appointmentType       String    @default("scheduled")
  tutorNotified         Boolean   @default(false)
  whatsappConfirmationStatus  String?   // 'pending' | 'confirmed' | 'reschedule_requested' | 'invalid_reply'
  whatsappConfirmationSentAt  DateTime?
  whatsappConfirmationReplyAt DateTime?
  awaitingWhatsappReply       Boolean   @default(false)
  whatsappLastMessageId       String?
  whatsappReplyText           String?
  confirmedVia                String?   // 'whatsapp' | 'manual' | etc
  reminderSentAt              DateTime?   // lembrete simples
  confirmationRequestSentAt   DateTime?   // pedido de confirmação interativo
  followUpSentAt              DateTime?
  createdAt             DateTime  @default(now())
  updatedAt     DateTime @updatedAt

  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)
  boardingStay BoardingStay?
  hospitalizationStay HospitalizationStay?

  @@map("appointments")
}

model MedicalRecord {
  id          String   @id @default(uuid())
  petId       String
  date        DateTime
  description String
  diagnosis   String?
  diagnosisType String?
  painScore     Int?
  mucousMembranes String?
  capillaryRefillTime String?
  hydrationLevel String?
  bodyConditionScore String?
  systemicEvaluation String?
  treatment   String?
  veterinarianId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)
  @@map("medical_records")
}

model Vaccination {
  id          String   @id @default(uuid())
  petId       String
  name        String
  date        DateTime
  nextDueDate DateTime?
  batch       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)
  @@map("vaccinations")
}

model ServiceCatalogItem {
  id           String   @id @default(uuid())
  name         String
  category     String
  price        Float
  duration     Int?
  active       Boolean  @default(true)
  description  String?
  observations String?
  alerts       String?
  parentId     String?
  parent       ServiceCatalogItem?  @relation("SubServices", fields: [parentId], references: [id])
  children     ServiceCatalogItem[] @relation("SubServices")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@map("service_catalog")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  category    String
  sku         String
  price       Float
  stock       Int      @default(0)
  minStock    Int      @default(5)
  description String?
  unit        String?
  expirationDate DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  batches     ProductBatch[]
  @@map("products")
}

model ProductBatch {
  id             String   @id @default(uuid())
  productId      String
  code           String
  quantity       Int
  expirationDate DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@map("product_batches")
}

model Kennel {
  id        String   @id @default(uuid())
  name      String
  size      String // 'small', 'medium', 'large'
  status    String // 'available', 'maintenance'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("kennels")
}

model BoardingStay {
  id             String   @id @default(uuid())
  petId          String
  appointmentId  String?  @unique
  appointment    Appointment? @relation(fields: [appointmentId], references: [id])
  checkIn        DateTime
  checkOut       DateTime
  actualCheckIn  DateTime?
  actualCheckOut DateTime?
  kennelNumber   String
  status         String
  notes          String?
  dailyRate      Float
  totalPrice     Float?
  specialInstructions String?
  belongings     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  services    BoardingService[]
  @@map("boarding_stays")
}

model BoardingService {
  id          String   @id @default(uuid())
  boardingId  String
  serviceId   String?
  productId   String?
  batchId     String?
  name        String
  quantity    Int
  unitPrice   Float
  totalPrice  Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  boarding BoardingStay @relation(fields: [boardingId], references: [id], onDelete: Cascade)
  @@map("boarding_services")
}

model Sale {
  id        String   @id @default(uuid())
  date      DateTime @default(now())
  clientId  String?
  petId     String?
  total     Float
  status    String
  items     SaleItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("sales")
}

model SaleItem {
  id        String   @id @default(uuid())
  saleId    String
  productId String
  productName String
  quantity  Int
  unitPrice Float
  total     Float
  batchId   String?
  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  @@map("sale_items")
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  category    String
  assignee    String
  dueDate     DateTime
  status      String
  priority    String
  notifiedOverdue Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("tasks")
}

model Organization {
  id        String   @id @default(uuid())
  name      String   @default("My Pet Care")
  settings  String?  // JSON string
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("organizations")
}

model AppointmentTemplate {
  id                  String   @id @default(uuid())
  name                String
  description         String
  services            String   // JSON string of TemplateItem[]
  defaultDurationDays Int
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  @@map("appointment_templates")
}

model MessageTemplate {
  id        String   @id @default(uuid())
  type      String
  title     String
  content   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("message_templates")
}

model NotificationLog {
  id         String   @id @default(uuid())
  clientId   String
  clientName String
  petName    String?
  type       String
  message    String
  sentAt     DateTime @default(now())
  status     String   @default("sent")
  manual     Boolean  @default(false)
  createdAt  DateTime @default(now())
  @@map("notification_logs")
}

model HospitalizationStay {
  id             String   @id @default(uuid())
  petId          String
  appointmentId  String?  @unique
  veterinarianId String?
  reasonForAdmission String?
  status         String   @default("admitted") // 'admitted', 'treatment', 'discharged', 'deceased'
  expectedDischargeDate DateTime?
  checkIn        DateTime @default(now())
  checkOut       DateTime?
  dailyRate      Float?
  kennelNumber   String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  pet            Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  appointment    Appointment? @relation(fields: [appointmentId], references: [id])
  logs           HospitalizationLog[]

  @@map("hospitalization_stays")
}

model HospitalizationLog {
  id                 String   @id @default(uuid())
  hospitalizationId  String
  timestamp          DateTime @default(now())
  type               String   @default("note") // 'note', 'medication', 'vitals'
  heartRate          Int?
  temperature        Float?
  medicationGiven    String?
  doctorNotes        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  hospitalization    HospitalizationStay @relation(fields: [hospitalizationId], references: [id], onDelete: Cascade)

  @@map("hospitalization_logs")
}
